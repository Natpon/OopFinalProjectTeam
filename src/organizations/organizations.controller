import { Controller, Get, Post, Put, Patch, Delete, Param, Body } from '@nestjs/common';
import { OrganizationsService } from './organizations.service';
import { CreateOrganizationDto } from './dto/create-organization.dto';
import { UpdateOrganizationDto } from './dto/update-organization.dto';
import { ApiResponse } from '@/common/interfaces/api-response.interface';
import { Organization } from './entities/organization.entity';

@Controller('organizations')
export class OrganizationsController {
  constructor(private readonly organizationsService: OrganizationsService) {}

  @Get()
  findAll(): ApiResponse<Organization[]> {
    return {
      success: true,
      message: 'Organizations retrieved successfully',
      data: this.organizationsService.findAll(),
    };
  }

  @Get(':id')
  findOne(@Param('id') id: string): ApiResponse<Organization> {
    return {
      success: true,
      message: 'Organization retrieved successfully',
      data: this.organizationsService.findOne(id),
    };
  }

  @Post()
  /*create(@Body() dto: CreateOrganizationDto): ApiResponse<Organization> {
    return {
      success: true,
      message: 'Organization created successfully',
      data: this.organizationsService.create(dto),
    };
  }*/
  

  @Put(':id')
  update(
    @Param('id') id: string,
    @Body() dto: UpdateOrganizationDto,
  ): ApiResponse<Organization> {
    return {
      success: true,
      message: 'Organization updated successfully',
      data: this.organizationsService.update(id, dto),
    };
  }

  @Patch(':id')
  partialUpdate(
    @Param('id') id: string,
    @Body() dto: UpdateOrganizationDto,
  ): ApiResponse<Organization> {
    return {
      success: true,
      message: 'Organization partially updated successfully',
      data: this.organizationsService.update(id, dto),
    };
  }

  @Delete(':id')
  remove(@Param('id') id: string): ApiResponse<null> {
    this.organizationsService.remove(id);
    return {
      success: true,
      message: 'Organization deleted successfully',
      data: null,
    };
  }
}